DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_client_id
MONGODB_URI=mongodb://127.0.0.1:27017/stratis

# Optional for fast command deployment in one guild during development
DISCORD_GUILD_ID=

# Optional Bloxlink token if you have partner/pro access
BLOXLINK_API_TOKEN=

# Optional Roblox .ROBLOSECURITY cookie for extra endpoints
ROBLOX_COOKIE=

# Optional: custom bot invite permissions integer
BOT_INVITE_PERMISSIONS=274878221376
